<style>
  :root {
    --bg: #080808; --bg1: #0f0f0f; --bg2: #141414; --bg3: #1a1a1a;
    --border: #1e1e1e; --text: #f0f0f0; --sub: #666; --muted: #333;
    --yellow: #F5C542; --blue: #4FC3F7; --green: #A5D6A7;
    --pink: #F48FB1; --purple: #CE93D8; --orange: #FF8A65;
    --font: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    --fontb: 'Barlow', sans-serif;
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bot: env(safe-area-inset-bottom, 0px);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { height: 100%; overscroll-behavior: none; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); overflow: hidden; }
  button { font-family: var(--font); cursor: pointer; border: none; background: none; }
  input { font-family: var(--fontb); }
  ::-webkit-scrollbar { display: none; }

  /* LAYOUT */
  #app { display: flex; flex-direction: column; height: 100dvh; }
  #header { padding: calc(var(--safe-top) + 12px) 16px 10px; background: var(--bg1); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  #tabs { display: flex; background: var(--bg1); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  #content { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
  #bottom-nav { display: flex; background: var(--bg1); border-top: 1px solid var(--border); padding-bottom: var(--safe-bot); flex-shrink: 0; }

  /* HEADER */
  .header-sub { font-size: 9px; letter-spacing: 4px; color: var(--sub); margin-bottom: 2px; }
  .header-title { font-size: 28px; font-weight: 900; letter-spacing: -1px; line-height: 1; }
  .header-title span { color: var(--yellow); }
  .header-info { font-size: 10px; color: var(--muted); margin-top: 2px; }

  /* TABS (top) */
  .tab-btn { flex: 1; padding: 11px 0; font-size: 11px; font-family: var(--font); font-weight: 700; letter-spacing: 2px; color: var(--muted); border-bottom: 2px solid transparent; transition: all .15s; }
  .tab-btn.active { color: var(--yellow); border-bottom-color: var(--yellow); }

  /* BOTTOM NAV */
  .nav-btn { flex: 1; padding: 10px 0; display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 9px; letter-spacing: 1px; color: var(--muted); transition: color .15s; }
  .nav-btn.active { color: var(--yellow); }
  .nav-icon { font-size: 20px; line-height: 1; }

  /* DAY SELECTOR */
  .day-strip { padding: 12px 14px 0; overflow-x: auto; }
  .day-strip-inner { display: flex; gap: 7px; min-width: max-content; padding-bottom: 12px; }
  .day-pill { padding: 8px 13px; border-radius: 8px; border: 2px solid var(--border); font-size: 11px; font-weight: 700; letter-spacing: 1px; transition: all .15s; text-align: center; min-width: 52px; }
  .day-pill .dl { font-size: 11px; }
  .day-pill .dt { font-size: 9px; margin-top: 2px; opacity: .7; }

  /* WORKOUT CARD */
  .wk-header { padding: 14px 14px 8px; display: flex; justify-content: space-between; align-items: flex-start; }
  .wk-focus { font-size: 10px; letter-spacing: 3px; font-weight: 700; margin-bottom: 3px; }
  .wk-name { font-size: 24px; font-weight: 900; letter-spacing: -.5px; }
  .wk-pct { font-size: 28px; font-weight: 900; }
  .wk-count { font-size: 10px; color: var(--sub); }
  .progress-bar { height: 3px; background: var(--bg3); margin: 0 14px 14px; border-radius: 2px; }
  .progress-fill { height: 100%; border-radius: 2px; transition: width .4s ease; }

  /* EXERCISE ROW */
  .ex-list { padding: 0 10px 16px; }
  .ex-row { display: flex; align-items: center; gap: 0; border-radius: 10px; margin-bottom: 8px; overflow: hidden; border: 1px solid var(--border); background: var(--bg1); transition: opacity .2s; }
  .ex-row.done { opacity: .4; }
  .ex-img { width: 72px; height: 72px; object-fit: cover; flex-shrink: 0; background: var(--bg2); }
  .ex-img-placeholder { width: 72px; height: 72px; flex-shrink: 0; background: var(--bg2); display: flex; align-items: center; justify-content: center; font-size: 26px; }
  .ex-body { flex: 1; padding: 10px 10px; min-width: 0; }
  .ex-name { font-size: 15px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ex-muscle { font-size: 11px; color: var(--sub); margin-top: 2px; }
  .ex-detail { font-size: 12px; font-weight: 700; margin-top: 4px; }
  .ex-check { width: 52px; height: 72px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .check-circle { width: 28px; height: 28px; border-radius: 50%; border: 2px solid var(--muted); display: flex; align-items: center; justify-content: center; transition: all .15s; }
  .check-circle.checked { border-color: transparent; }
  .check-circle .tick { font-size: 14px; font-weight: 900; color: #000; display: none; }
  .check-circle.checked .tick { display: block; }

  /* REST LOG */
  .rest-log { margin: 0 14px 16px; background: var(--bg1); border-radius: 10px; border: 1px solid var(--border); overflow: hidden; }
  .rest-log-head { padding: 10px 14px; font-size: 10px; letter-spacing: 3px; color: var(--sub); border-bottom: 1px solid var(--border); }
  .rest-log-body { padding: 12px 14px; }
  .log-inputs { display: flex; gap: 8px; }
  .log-input { flex: 1; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--bg3); background: var(--bg2); color: var(--text); font-size: 14px; outline: none; }
  .log-input:focus { border-color: var(--yellow); }
  .log-btn { padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 700; }
  .log-add-btn { width: 100%; padding: 11px; border: 1px dashed var(--bg3); border-radius: 8px; color: var(--sub); font-size: 13px; }
  .log-saved { font-size: 12px; color: var(--sub); margin-top: 8px; }

  /* REST DAY */
  .rest-day { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 20px; text-align: center; }
  .rest-day .emoji { font-size: 56px; margin-bottom: 16px; }
  .rest-day .title { font-size: 26px; font-weight: 900; color: var(--muted); }
  .rest-day .sub { font-size: 13px; color: var(--muted); margin-top: 6px; font-family: var(--fontb); }

  /* NUTRITION */
  .nut-macros { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 14px 14px 0; }
  .macro-card { background: var(--bg1); border-radius: 8px; border: 1px solid var(--border); padding: 10px 6px; text-align: center; }
  .macro-label { font-size: 9px; letter-spacing: 2px; color: var(--sub); margin-bottom: 4px; }
  .macro-val { font-size: 22px; font-weight: 900; }
  .macro-unit { font-size: 9px; color: var(--muted); }
  .meal-list { padding: 14px; }
  .meal-row { margin-bottom: 8px; border-radius: 10px; border: 1px solid var(--border); overflow: hidden; }
  .meal-head { display: flex; align-items: center; justify-content: space-between; padding: 13px 14px; background: var(--bg1); }
  .meal-head-left { display: flex; align-items: center; gap: 10px; }
  .meal-time { font-size: 11px; font-weight: 700; min-width: 38px; }
  .meal-name { font-size: 14px; font-weight: 700; }
  .meal-kcal { font-size: 14px; font-weight: 700; }
  .meal-body { background: #0d0d0d; padding: 12px 14px; border-top: 1px solid var(--border); }
  .meal-item { font-size: 12px; color: #aaa; padding: 3px 0; border-bottom: 1px solid var(--bg3); font-family: var(--fontb); }
  .supps { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
  .supp-tag { font-size: 10px; padding: 3px 7px; border-radius: 4px; background: var(--bg3); color: #777; border: 1px solid #222; }
  .meal-macros { display: flex; gap: 14px; margin-top: 8px; }
  .meal-macro { font-size: 11px; color: #555; font-family: var(--fontb); }
  .meal-macro strong { color: #aaa; }
  .nut-notes { margin: 0 14px 24px; background: var(--bg1); border-radius: 10px; border: 1px solid var(--border); padding: 14px; }
  .nut-note-title { font-size: 10px; letter-spacing: 3px; color: var(--sub); margin-bottom: 10px; }
  .nut-note { display: flex; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--bg3); }
  .nut-note-arrow { color: var(--yellow); font-size: 13px; flex-shrink: 0; margin-top: 1px; }
  .nut-note-text { font-size: 12px; color: #888; font-family: var(--fontb); line-height: 1.5; }

  /* REGISTO */
  .reg-section { padding: 14px; }
  .reg-title { font-size: 10px; letter-spacing: 3px; color: var(--sub); margin-bottom: 12px; }
  .week-card { background: var(--bg1); border-radius: 10px; border: 1px solid var(--border); overflow: hidden; margin-bottom: 14px; }
  .week-card-head { padding: 11px 14px; background: #111; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .week-key { font-size: 13px; font-weight: 700; }
  .week-weight { font-size: 14px; font-weight: 700; color: var(--yellow); }
  .week-table { width: 100%; border-collapse: collapse; }
  .week-table th { padding: 7px 14px; font-size: 9px; letter-spacing: 2px; color: var(--muted); text-align: left; border-bottom: 1px solid var(--bg3); background: #0a0a0a; }
  .week-table td { padding: 9px 14px; font-size: 13px; border-bottom: 1px solid var(--bg3); }
  .week-total { padding: 9px 14px; font-size: 11px; color: var(--sub); background: #0a0a0a; }
  .week-total strong { color: #aaa; }
  .stats-card { background: var(--bg1); border-radius: 10px; border: 1px solid var(--border); padding: 14px; margin-bottom: 14px; }
  .stat-row { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid var(--bg3); }
  .stat-label { font-size: 12px; color: var(--sub); font-family: var(--fontb); }
  .stat-val { font-size: 13px; font-weight: 700; }
  .empty-state { text-align: center; padding: 50px 20px; }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-title { font-size: 16px; font-weight: 700; color: var(--muted); }
  .empty-sub { font-size: 12px; color: var(--muted); margin-top: 5px; font-family: var(--fontb); }

  /* INSTALL BANNER */
  #install-banner { position: fixed; bottom: calc(56px + var(--safe-bot)); left: 12px; right: 12px; background: #1a1a1a; border: 1px solid #333; border-radius: 12px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,.6); }
  #install-banner.hidden { display: none; }
  .install-icon { font-size: 28px; flex-shrink: 0; }
  .install-text { flex: 1; }
  .install-title { font-size: 14px; font-weight: 700; }
  .install-sub { font-size: 11px; color: var(--sub); margin-top: 2px; font-family: var(--fontb); }
  .install-btn { padding: 8px 14px; border-radius: 8px; background: var(--yellow); color: #000; font-size: 13px; font-weight: 700; flex-shrink: 0; }
  .install-close { font-size: 18px; color: var(--muted); padding: 4px; flex-shrink: 0; }

  /* ARROW for chevron */
  .chevron { font-size: 12px; color: var(--muted); transition: transform .2s; }
  .chevron.open { transform: rotate(180deg); }

  /* iOS install hint */
  #ios-hint { position: fixed; bottom: calc(56px + var(--safe-bot) + 8px); left: 12px; right: 12px; background: #1a1a1a; border: 1px solid #333; border-radius: 12px; padding: 14px 16px; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,.6); }
  #ios-hint.hidden { display: none; }
  .ios-hint-close { float: right; font-size: 18px; color: var(--muted); }
  .ios-hint-text { font-size: 13px; font-family: var(--fontb); color: #aaa; line-height: 1.6; }
  .ios-hint-text strong { color: var(--text); }
</style>
</head>
